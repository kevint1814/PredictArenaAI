# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram group chat ID (negative number, e.g. -1001234567890)
# Forward any group message to @userinfobot to get it
TELEGRAM_GROUP_ID=-1001234567890

# Admin's Telegram user ID — message @userinfobot to get yours
ADMIN_TELEGRAM_ID=123456789

# Second player's Telegram user ID
USER_2_TELEGRAM_ID=987654321

# Optional display name placeholders — players set their own name via /start
ADMIN_NAME=Player 1
USER_2_NAME=Player 2

# ── AI Provider (set at least one) ────────────────────────────────────────────
# Priority: OpenAI > Grok > Gemini — first key found wins

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Grok (xAI) — https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-3-mini-fast

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Football Data ──────────────────────────────────────────────────────────────
# Tavily — production web search for Arena (app.tavily.com — free: 1000/month)
TAVILY_API_KEY=

# football-data.org — FREE, no daily cap, covers WC 2026
# Register at https://www.football-data.org/client/register
# Optional — only needed for /syncmatches. Add matches manually with /addmatch instead.
FOOTBALL_DATA_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Local: leave as default. Render: set to /data/predicarena.db (persistent disk)
DATABASE_PATH=predicarena.db

# ── Webhook (Render / production only) ────────────────────────────────────────
# Set to your Render service URL, e.g. https://predicarena-ai.onrender.com
# Leave blank for local polling mode
WEBHOOK_URL=
WEBHOOK_SECRET=change_me_to_a_random_string
